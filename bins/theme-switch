#!/bin/zsh
set -e

# Usage: theme-switch nord | theme-switch catppuccin | theme-switch gruvbox
#
# Changes the `theme` value in modules/theme.nix, rebuilds — Nix propagates to
# starship, wezterm, bat, nvim, sketchybar, and opencode (tui theme via
# programs.opencode) — then reloads sketchybar. Restart Neovim and OpenCode.

NEW_THEME="$1"
case "$NEW_THEME" in
  nord|catppuccin|gruvbox) ;;
  *)
    echo "Usage: theme-switch nord|catppuccin|gruvbox" >&2
    exit 1
    ;;
esac

REPO=~/my-dotfiles

# 1. Update the `theme` value in modules/theme.nix
sed -i '' "s/^  config.dotfiles.theme = \".*\";/  config.dotfiles.theme = \"$NEW_THEME\";/" "$REPO/modules/theme.nix"

# 2. Rebuild — Nix propagates to starship, wezterm, bat, nvim, sketchybar,
#    and opencode (tui theme via programs.opencode).
pushd "$REPO"
alejandra . &>/dev/null
sudo darwin-rebuild switch --flake .
popd

# 3. Reload sketchybar so it re-sources colors.sh with the new theme.
#    (colors.sh reads ~/.config/theme at source time via sketchybarrc.)
sketchybar --reload

echo "Theme switched to $NEW_THEME. Restart Neovim and OpenCode to apply."
