#!/bin/zsh
set -e

# Usage: theme-switch nord | theme-switch catppuccin | theme-switch gruvbox
#
# Changes the `theme` var in home.nix, rebuilds (Nix propagates to starship,
# wezterm, bat, nvim, sketchybar), then patches opencode (Nix-blind — out-of-
# store symlink) and reloads sketchybar. Restart Neovim and OpenCode manually.

NEW_THEME="$1"
case "$NEW_THEME" in
  nord|catppuccin|gruvbox) ;;
  *)
    echo "Usage: theme-switch nord|catppuccin|gruvbox" >&2
    exit 1
    ;;
esac

REPO=~/my-dotfiles

# 1. Update the `theme` var in home.nix
sed -i '' "s/^  theme = \".*\";/  theme = \"$NEW_THEME\";/" "$REPO/nix/modules/home.nix"

# 2. Rebuild — Nix propagates to starship, wezterm, bat, nvim, sketchybar
pushd "$REPO/nix"
alejandra . &>/dev/null
sudo darwin-rebuild switch --flake .
popd

# 3. Patch opencode tui.json (Nix-blind — out-of-store symlink, Nix can't
#    manage individual files inside config/opencode/)
jq --arg t "$NEW_THEME" '.theme = $t' \
  "$REPO/config/opencode/tui.json" > "$REPO/config/opencode/tui.json.tmp" \
  && mv "$REPO/config/opencode/tui.json.tmp" "$REPO/config/opencode/tui.json"

# 4. Reload sketchybar so it re-sources colors.sh with the new theme.
#    (colors.sh reads ~/.config/theme at source time via sketchybarrc.)
sketchybar --reload

echo "Theme switched to $NEW_THEME. Restart Neovim and OpenCode to apply."
